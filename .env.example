# ── Terraform variables ───────────────────────────────────────
# Project name used as prefix for AWS resources
TF_VAR_project_name="supplier-email"
# AWS region for all resources
TF_VAR_aws_region="eu-west-1"
# Domain name verified in SES for receiving email
TF_VAR_domain_name="example.com"
# Admin email for notifications
TF_VAR_admin_email="admin@example.com"
# Environment name (stage, prod, etc.)
TF_VAR_environment="stage"
# Local part of the receiving email address (e.g. inbox → inbox@example.com)
TF_VAR_receipt_local_part="inbox"
# S3 bucket name for raw inbound emails
TF_VAR_bucket_name="supplier-email-inbound"
# SQS queue name for email processing
TF_VAR_queue_name="supplier-email-inbound"
# SES receipt rule set name
TF_VAR_rule_set_name="supplier-email-inbound"
# Whether to activate the SES rule set (set false if another rule set is active)
TF_VAR_activate_rule_set=true
# Whether Terraform should create/manage the SES domain identity
TF_VAR_manage_ses_identity=false
# Resource tags
TF_VAR_tags='{ Project = "supplier-email", Environment = "stage" }'

# ── Application ───────────────────────────────────────────────
# Environment name for the app
APP_ENV=stage

# ── Backend ───────────────────────────────────────────────────
# Port the NestJS backend listens on
BACKEND_PORT=5001
# AWS region (must match TF_VAR_aws_region)
AWS_REGION=eu-west-1
# Domain used for SES sending/receiving
DOMAIN_NAME=example.com
# S3 bucket where SES stores raw emails (must match TF_VAR_bucket_name)
RAW_EMAIL_BUCKET=supplier-email-inbound
# Full SQS queue URL (from Terraform output)
SQS_QUEUE_URL=https://sqs.eu-west-1.amazonaws.com/123456789012/supplier-email-inbound
# Email address that receives inbound mail
RECEIPT_EMAIL=inbox@example.com
# Admin email for deal-question notifications
ADMIN_EMAIL=admin@example.com
# Sender address for outgoing notifications (must be verified in SES)
SES_FROM_EMAIL=noreply@example.com
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname
# OpenRouter API key for LLM calls
OPENROUTER_API_KEY=sk-or-v1-...
# OpenRouter model identifier
OPENROUTER_MODEL=openrouter/auto
# Basic-auth username for the backend API
BACKEND_AUTH_USERNAME=admin
# Basic-auth password for the backend API
BACKEND_AUTH_PASSWORD=changeme
# Secret used to sign JWTs
JWT_SECRET=generate-a-random-secret-here
# Access token lifetime in seconds
ACCESS_TOKEN_TTL_SECONDS=3600
# Refresh token lifetime in seconds
REFRESH_TOKEN_TTL_SECONDS=2592000

# ── Frontend ──────────────────────────────────────────────────
# Public URL of the backend API
BACKEND_URL=http://localhost:5001
# Port the Vite dev server listens on
FRONTEND_PORT=5000
# Allowed hosts for Vite (comma-separated)
FRONTEND_ALLOWED_HOSTS=localhost
# Frontend basic-auth username (should match backend)
FRONTEND_AUTH_USERNAME=admin
# Frontend basic-auth password (should match backend)
FRONTEND_AUTH_PASSWORD=changeme
